 data/ingredients.json | 111 +++++++++++++++++++++++++++++-
 docs/DESIGN.md        |  47 +++++++++----
 index.html            |   5 ++
 src/generator.js      | 118 +++++++++++++++++++++-----------
 src/ui.js             |  32 +++++++++
 6 files changed, 411 insertions(+), 55 deletions(-)

