    "plague":    { "label": "Plague",    "price_mult": 1.8, "max_import_distance": 0, "note": "Doors bar at dusk. The kitchen serves what arrived in sealed barrels." },
    "isolation": { "label": "Isolation", "price_mult": 1.2, "max_import_distance": 0, "note": "Roads are impassable. The larder is whatever the last harvest left." },
    "siege":     { "label": "Siege",     "price_mult": 2.0, "max_import_distance": 0, "note": "Walls stand closed. Every ingredient is rationed." }
  },
