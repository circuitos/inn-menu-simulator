{
  "biomes": {
    "coastal":    { "label": "Coastal",    "description": "Temperate maritime. Fish, shellfish, citrus where warm." },
    "heartland":  { "label": "Heartland",  "description": "Temperate plains and forest. Grain, pork, game, orchard fruit." },
    "highland":   { "label": "Highland",   "description": "Cold mountain. Mutton, dairy, roots, smoked meats." },
    "arid":       { "label": "Arid",       "description": "Mediterranean to semi-desert. Olive, legume, goat, warming spices." },
    "frostlands": { "label": "Frostlands", "description": "Arctic subarctic. Seal, reindeer, fermented dairy, preserved fish." }
  },
  "biome_relations": {
