    "coastal":    { "regional": ["heartland","highland","arid","frostlands"], "distant": [] },
    "heartland":  { "regional": ["coastal","highland","arid","frostlands"],   "distant": [] },
    "highland":   { "regional": ["coastal","heartland","frostlands"],         "distant": ["arid"] },
